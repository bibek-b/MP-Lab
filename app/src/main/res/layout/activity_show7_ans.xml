<TableLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <TableRow>
        <TextView
            android:text="Question"
            android:textStyle="bold"/>

        <TextView
            android:text="Answer"
            android:textStyle="bold"
            android:paddingStart="20dp"/>
    </TableRow>

    <TableRow>
        <TextView android:text="Q1"/>
        <TextView android:id="@+id/ans1" android:paddingStart="20dp"/>
    </TableRow>

    <TableRow>
        <TextView android:text="Q2"/>
        <TextView android:id="@+id/ans2" android:paddingStart="20dp"/>
    </TableRow>

    <TableRow>
        <TextView android:text="Q3"/>
        <TextView android:id="@+id/ans3" android:paddingStart="20dp"/>
    </TableRow>

    <TableRow>
        <TextView android:text="Q4"/>
        <TextView android:id="@+id/ans4" android:paddingStart="20dp"/>
    </TableRow>

    <TableRow>
        <TextView android:text="Q5"/>
        <TextView android:id="@+id/ans5" android:paddingStart="20dp"/>
    </TableRow>

    <TableRow>
        <TextView android:text="Q6"/>
        <TextView android:id="@+id/ans6" android:paddingStart="20dp"/>
    </TableRow>

</TableLayout>